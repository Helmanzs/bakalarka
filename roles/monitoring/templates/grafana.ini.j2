[server]
http_port = {{ grafana_port }}
domain = localhost

[security]
admin_user = {{ grafana_admin_user }}
admin_password = {{ grafana_admin_password }}
# Allow embedding in iframes (useful for sharing)
allow_embedding = true

[users]
allow_sign_up = false

[auth.anonymous]
# Set to true to allow unauthenticated viewing (convenient for lab use)
enabled = false

[dashboards]
default_home_dashboard_path = /var/lib/grafana/dashboards/system_overview.json

[log]
mode = console
level = warn

[analytics]
reporting_enabled = false
check_for_updates = false
