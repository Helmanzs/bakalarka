#cloud-config
package_update: true
packages:
{% for pkg in shared_packages %}
  - {{ pkg }}
{% endfor %}

users:
  - name: root #{{ lxd_ssh_user | default('root') }}
    ssh_authorized_keys:
      - {{ lookup('file', lxd_ssh_pubkey_file | default('~/.ssh/id_ed25519.pub')) }}
    #sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash