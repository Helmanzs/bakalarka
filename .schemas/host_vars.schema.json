{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ansible Tasks File Custom",
  "type": "object",
  "required": [
    "vm_name",
    "vm_profiles",
    "vm_packages",
    "data_file",
    "db_table",
    "db_host",
    "db_port",
    "vm_disk_size",
    "db_version"
  ],
  "properties": {
    "db_host": { "type": "string" },
    "db_port": { "type": "number" },
    "vm_profiles": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "db_download_url": { "type": "string", "format": "uri" },
    "db_key_url": { "type": "string", "format": "uri" },
    "db_engine": { "type": "string" },
    "db_table": { "type": "string" },
    "vm_disk_size": { "type": "string" },
    "vm_name": { "type": "string" },
    "vm_packages": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "db_version": { "type": "string" },
    "db_checksum": { "type": "string" }
  }
}
